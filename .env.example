# TG AI Poster Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
# NEVER commit .env file to version control!

# ===================================
# TELEGRAM BOT (Mode A)
# ===================================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Channel ID (can be @username or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel

# ===================================
# TELETHON (Mode B - User Account)
# ===================================
# WARNING: Using Telethon with your main account carries ban risk.
# Get credentials from https://my.telegram.org
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef1234567890abcdef1234567890
TELETHON_PHONE=+79991234567

# ===================================
# LLM API KEYS
# ===================================
# GLM-5 API Key (Z.AI) - PRIMARY
GLM_API_KEY=your_glm_api_key_here

# OpenAI API Key (optional backup)
OPENAI_API_KEY=sk-...

# Anthropic API Key (optional, for Claude)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API Key (optional)
DEEPSEEK_API_KEY=sk-...

# ===================================
# ADMIN SETTINGS
# ===================================
# Your Telegram user ID for admin notifications
# Get your ID from @userinfobot on Telegram
ADMIN_TELEGRAM_ID=123456789

# ===================================
# DATABASE (optional)
# ===================================
# PostgreSQL connection string (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/tg_poster

# ===================================
# REDIS (optional)
# ===================================
# Redis connection for queueing
# REDIS_URL=redis://localhost:6379/0
